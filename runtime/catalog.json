      "dockerfile": "container/providers/wine/Dockerfile",
      "buildArg": "WINE_VERSION",
      "defaultVersion": "9.0",
      "notes": "Wine Stable OCI base \u2014 built from WineHQ packages.",
      "versions": {
        "9.0": {
          "buildValue": "9.0",
          "tag": "9.0",
          "channel": "stable",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    },
    "staging": {
      "displayName": "Wine Staging",
      "launcher": "wine",
      "localImage": "winforge/wine-staging",
      "publishedImageName": "winforge-wine-staging",
