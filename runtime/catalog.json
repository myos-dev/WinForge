{
  "schemaVersion": "winforge.runtime-catalog/v0",
  "defaultRegistry": "ghcr.io/myos-dev",
  "providers": {
    "wine": {
      "displayName": "Wine Stable",
      "launcher": "wine",
      "localImage": "winforge/wine",
