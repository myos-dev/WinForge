      "buildArg": "WINE_VERSION",
      "defaultVersion": "9.0",
      "notes": "Wine Staging OCI base \u2014 WineHQ staging packages.",
      "versions": {
        "9.0": {
          "buildValue": "9.0",
          "tag": "9.0",
          "channel": "staging",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    },
    "proton-ge": {
      "displayName": "GE-Proton",
      "launcher": "proton",
      "localImage": "winforge/proton-ge",
      "publishedImageName": "winforge-proton-ge",
      "dockerfile": "container/providers/proton-ge/Dockerfile",
      "buildArg": "GE_PROTON_TAG",
