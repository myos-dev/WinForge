{
  "schemaVersion": "winforge.runtime-catalog/v0",
  "defaultRegistry": "ghcr.io/myos-dev",
  "providers": {
    "wine": {
      "displayName": "Wine Stable",
      "launcher": "wine",
      "localImage": "winforge/wine",
      "publishedImageName": "winforge-wine",
      "dockerfile": "container/providers/wine/Dockerfile",
      "buildArg": "WINE_VERSION",
      "defaultVersion": "9.0",
      "notes": "Wine Stable OCI base \u2014 built from WineHQ packages.",
      "versions": {
        "9.0": {
          "buildValue": "9.0",
          "tag": "9.0",
          "channel": "stable",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    },
    "staging": {
      "displayName": "Wine Staging",
      "launcher": "wine",
      "localImage": "winforge/wine-staging",
      "publishedImageName": "winforge-wine-staging",
      "dockerfile": "container/providers/wine-staging/Dockerfile",
      "buildArg": "WINE_VERSION",
      "defaultVersion": "9.0",
      "notes": "Wine Staging OCI base \u2014 WineHQ staging packages.",
      "versions": {
        "9.0": {
          "buildValue": "9.0",
          "tag": "9.0",
          "channel": "staging",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    },
    "umu-proton-ge": {
      "displayName": "UMU + GE-Proton",
      "launcher": "umu",
      "localImage": "winforge/umu-proton-ge",
      "publishedImageName": "winforge-umu-proton-ge",
      "dockerfile": "container/providers/umu-proton-ge/Dockerfile",
      "buildArg": "GE_PROTON_TAG",
      "defaultVersion": "GE-Proton9-27",
      "notes": "UMU launcher stack for GE-Proton runner releases.",
      "versions": {
        "GE-Proton9-27": {
          "buildValue": "GE-Proton9-27",
          "tag": "GE-Proton9-27",
          "channel": "ge-stable",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    }
  }
}
