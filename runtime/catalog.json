      "versions": {
        "9.0": {
          "buildValue": "9.0",
          "tag": "9.0",
          "channel": "staging",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    },
    "proton": {
      "displayName": "Valve Proton Source Seed",
      "launcher": "proton",
