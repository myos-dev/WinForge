        "GE-Proton9-27": {
          "buildValue": "GE-Proton9-27",
          "tag": "GE-Proton9-27",
          "channel": "ge-stable",
          "ciBuild": true,
          "runtimeUsable": true
        }
      }
    }
  }
}
